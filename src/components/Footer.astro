---
import newcastle from '../data/newcastle.json';
import durham from '../data/durham.json';
---
<footer aria-label="Site footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="DTRHair Home">
          <img src="/logo.jpg" alt="DTRHair" class="footer-logo-img" />
        </a>
        <p class="footer-tagline">Precision. Craft. Character.</p>
      </div>
      <div class="footer-social" aria-label="Social media links">
        <a href="https://www.instagram.com/dtrhair_/" class="social-link" aria-label="DTRHair on Instagram" target="_blank" rel="noopener">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="footer-grid">
      <div class="footer-branch">
        <h3 class="footer-branch-name">Newcastle</h3>
        <address>
          <p>{newcastle.address}</p>
        </address>
        <div class="footer-hours">
          {Object.entries(newcastle.hours).map(([day, hours]) => (
            <div class="footer-hours-row">
              <span>{day.substring(0, 3)}</span>
              <span class={hours === 'Closed' ? 'hours-closed' : ''}>{hours}</span>
            </div>
          ))}
        </div>
        <a href={newcastle.fresha_url} target="_blank" rel="noopener" class="footer-book-link">
          Book Newcastle &rarr;
        </a>
      </div>

      <div class="footer-branch">
        <h3 class="footer-branch-name">Durham</h3>
        <address>
          <p>{durham.address}</p>
        </address>
        <div class="footer-hours">
          {Object.entries(durham.hours).map(([day, hours]) => (
            <div class="footer-hours-row">
              <span>{day.substring(0, 3)}</span>
              <span class={hours === 'Closed' ? 'hours-closed' : ''}>{hours}</span>
            </div>
          ))}
        </div>
        <a href={durham.fresha_url} target="_blank" rel="noopener" class="footer-book-link">
          Book Durham &rarr;
        </a>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copyright">&copy; {new Date().getFullYear()} DTRHair. All rights reserved.</p>
      <button class="back-to-top" id="back-to-top" aria-label="Back to top">
        &uarr; Top
      </button>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    background: var(--surface);
    padding: 80px 0 40px;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 4rem;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .footer-logo {
    display: block;
    margin-bottom: 0.75rem;
    transition: opacity 0.2s;
  }
  .footer-logo:hover { opacity: 0.75; }
  .footer-logo-img {
    height: 52px;
    width: auto;
    display: block;
  }

  .footer-tagline {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-secondary);
    font-family: 'DM Sans', sans-serif;
  }

  .footer-social {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .social-link {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    border: 1px solid var(--border);
    transition: color 0.2s, border-color 0.2s;
  }
  .social-link:hover { color: var(--accent); border-color: var(--accent); }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin-bottom: 4rem;
    padding-top: 3rem;
    border-top: 1px solid var(--border);
  }
  @media (min-width: 640px) { .footer-grid { grid-template-columns: 1fr 1fr; } }

  .footer-branch-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  address {
    font-style: normal;
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    line-height: 1.7;
  }

  .footer-hours { margin-bottom: 1.5rem; }

  .footer-hours-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    color: var(--text-secondary);
    padding: 0.25rem 0;
  }
  .footer-hours-row span:first-child { color: var(--text-primary); font-weight: 400; }
  .hours-closed {
    font-style: italic;
    color: var(--text-secondary);
  }

  .footer-book-link {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    font-family: 'DM Sans', sans-serif;
    transition: opacity 0.2s;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .footer-book-link:hover { opacity: 0.7; }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-copyright {
    font-size: 0.8rem;
    color: var(--text-secondary);
    font-family: 'DM Sans', sans-serif;
  }

  .back-to-top {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-secondary);
    background: none;
    border: 1px solid var(--border);
    padding: 0.5rem 1rem;
    cursor: pointer;
    min-height: 44px;
    transition: color 0.2s, border-color 0.2s;
  }
  .back-to-top:hover { color: var(--accent); border-color: var(--accent); }
</style>

<script>
  document.getElementById('back-to-top')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
