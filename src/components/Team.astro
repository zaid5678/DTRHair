---
import newcastle from '../data/newcastle.json';
import durham from '../data/durham.json';

const allBarbers = [...newcastle.team, ...durham.team];
---
<section id="team" aria-labelledby="team-heading">
  <div class="container">
    <div class="team-header reveal">
      <span class="label">The Team</span>
      <div class="divider"></div>
      <h2 id="team-heading">Meet Your Barbers</h2>
    </div>

    <div class="team-grid">
      {allBarbers.map((barber, i) => (
        <article class={`barber-card reveal reveal-delay-${(i % 4) + 1}`} aria-label={barber.name}>
          <div class="barber-image-wrap">
            <img
              src={barber.image}
              alt={barber.image_placeholder ? `${barber.name} — placeholder` : barber.name}
              class="barber-img"
              loading="lazy"
              width="600"
              height="800"
            />
            <div class="barber-overlay"></div>
          </div>
          <div class="barber-info">
            <div class="barber-meta">
              <span class="barber-branch label">{barber.branch}</span>
            </div>
            <h3 class="barber-name">{barber.name}</h3>
            <p class="barber-bio">{barber.bio}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  #team {
    padding-top: 120px;
  }

  .team-header { margin-bottom: 4rem; }
  .team-header h2 {
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 300;
    letter-spacing: -0.03em;
    margin-top: 1rem;
  }

  .team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2px;
  }

  @media (min-width: 640px) {
    .team-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (min-width: 1024px) {
    .team-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .barber-card {
    background: var(--surface);
    border: 1px solid var(--border);
    overflow: hidden;
  }

  .barber-image-wrap {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    background: var(--surface-2);
  }

  .barber-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(1);
    transition: filter 0.4s ease, transform 0.4s ease;
  }

  .barber-card:hover .barber-img {
    filter: grayscale(0);
    transform: scale(1.03);
  }

  .barber-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(to top, rgba(240,237,232,0.7) 0%, transparent 100%);
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .barber-card:hover .barber-overlay { opacity: 1; }

  .barber-info {
    padding: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .barber-meta { margin-bottom: 0.5rem; }

  .barber-name {
    font-size: 1.6rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
    transition: color 0.2s;
  }
  .barber-card:hover .barber-name { color: var(--accent); }

  .barber-bio {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.7;
    font-weight: 300;
  }
</style>
