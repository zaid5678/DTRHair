---
import newcastle from '../data/newcastle.json';
import durham from '../data/durham.json';

type ServiceItem = { name: string; description: string; duration: string; price: number };
type ServiceGroup = { barber: string; category: string; items: ServiceItem[] };

function groupByBarber(services: ServiceGroup[]): Map<string, ServiceGroup[]> {
  const map = new Map<string, ServiceGroup[]>();
  for (const sg of services) {
    if (!map.has(sg.barber)) map.set(sg.barber, []);
    map.get(sg.barber)!.push(sg);
  }
  return map;
}

const nclByBarber = groupByBarber(newcastle.services as ServiceGroup[]);
const durByBarber = groupByBarber(durham.services as ServiceGroup[]);

function formatPrice(p: number) {
  return `£${p % 1 === 0 ? p.toFixed(0) : p.toFixed(2)}`;
}

const CALLOUT_NAME = 'Haircut - Callout';
---
<section id="services" aria-labelledby="services-heading">
  <div class="container">
    <div class="services-header reveal">
      <span class="label">Services</span>
      <div class="divider"></div>
      <h2 id="services-heading">What We Offer</h2>
    </div>

    <div class="tab-switcher reveal reveal-delay-1" role="tablist" aria-label="Branch selector">
      <button class="tab-btn active" id="tab-ncl" role="tab" aria-selected="true" aria-controls="services-ncl" data-branch="newcastle">
        Newcastle
      </button>
      <button class="tab-btn" id="tab-dur" role="tab" aria-selected="false" aria-controls="services-dur" data-branch="durham">
        Durham
      </button>
    </div>

    <!-- Newcastle panel -->
    <div id="services-ncl" role="tabpanel" aria-labelledby="tab-ncl" class="services-panel active">
      {[...nclByBarber.entries()].map(([barberName, groups]) => (
        <div class="barber-section reveal">
          <div class="barber-section-header">
            <h3 class="barber-section-name">{barberName}</h3>
            <div class="barber-section-rule"></div>
          </div>
          {groups.map((group) => (
            <div class="service-category-block">
              <p class="category-label">{group.category}</p>
              <ul role="list" class="service-list">
                {group.items.map((item) => (
                  <li class={`service-row${item.name === CALLOUT_NAME ? ' service-row--callout' : ''}`}>
                    <div class="service-main">
                      <div class="service-name-line">
                        <span class="service-name">{item.name}</span>
                        {item.name === CALLOUT_NAME && (
                          <span class="service-badge" aria-label="Home visit service">Home Visit</span>
                        )}
                      </div>
                      {item.description && (
                        <span class="service-desc">{item.description}</span>
                      )}
                    </div>
                    <span class="service-duration">{item.duration}</span>
                    <span class="service-price">{formatPrice(item.price)}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      ))}
    </div>

    <!-- Durham panel -->
    <div id="services-dur" role="tabpanel" aria-labelledby="tab-dur" class="services-panel" hidden>
      {[...durByBarber.entries()].map(([barberName, groups]) => (
        <div class="barber-section reveal">
          <div class="barber-section-header">
            <h3 class="barber-section-name">{barberName}</h3>
            <div class="barber-section-rule"></div>
          </div>
          {groups.map((group) => (
            <div class="service-category-block">
              <p class="category-label">{group.category}</p>
              <ul role="list" class="service-list">
                {group.items.map((item) => (
                  <li class="service-row">
                    <div class="service-main">
                      <div class="service-name-line">
                        <span class="service-name">{item.name}</span>
                      </div>
                      {item.description && (
                        <span class="service-desc">{item.description}</span>
                      )}
                    </div>
                    <span class="service-duration">{item.duration}</span>
                    <span class="service-price">{formatPrice(item.price)}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #services {
    padding-top: 120px;
    background: var(--surface);
  }

  .services-header { margin-bottom: 3rem; }
  .services-header h2 {
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 300;
    letter-spacing: -0.03em;
    margin-top: 1rem;
  }

  .tab-switcher {
    display: flex;
    margin-bottom: 3rem;
    border: 1px solid var(--border);
    width: fit-content;
  }
  .tab-btn {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-secondary);
    background: transparent;
    border: none;
    padding: 0.75rem 2rem;
    cursor: pointer;
    min-height: 44px;
    transition: background 0.2s, color 0.2s;
  }
  .tab-btn.active { background: var(--accent); color: #fff; }
  .tab-btn:not(.active):hover { background: var(--accent-dim); color: var(--text-primary); }

  .services-panel { display: none; }
  .services-panel.active { display: block; }

  /* Barber section */
  .barber-section { margin-bottom: 3.5rem; }

  .barber-section-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .barber-section-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    white-space: nowrap;
  }
  .barber-section-rule {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  /* Category within barber */
  .service-category-block { margin-bottom: 1.5rem; }
  .category-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .service-list { list-style: none; }

  .service-row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 0.75rem 1.5rem;
    align-items: start;
    padding: 0.9rem 0 0.9rem 0;
    border-bottom: 1px solid var(--border);
    position: relative;
    transition: padding-left 0.25s ease;
  }
  .service-row::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 0;
    background: var(--accent);
    transition: width 0.25s ease;
  }
  .service-row:hover { padding-left: 0.75rem; }
  .service-row:hover::before { width: 2px; }

  /* Callout — always has gold border + no hover effect needed */
  .service-row--callout {
    border-left: 3px solid var(--accent);
    padding-left: 0.75rem;
  }
  .service-row--callout::before { display: none; }

  .service-main {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .service-name-line {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .service-name {
    font-size: 0.95rem;
    color: var(--text-primary);
    font-weight: 400;
  }

  .service-badge {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 1px 6px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .service-desc {
    font-size: 0.8rem;
    color: var(--text-secondary);
    font-style: italic;
    line-height: 1.55;
    font-weight: 300;
  }

  .service-duration {
    font-size: 0.78rem;
    color: var(--text-secondary);
    font-weight: 300;
    white-space: nowrap;
    text-align: right;
    padding-top: 2px;
  }

  .service-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.15rem;
    color: var(--accent);
    font-weight: 500;
    white-space: nowrap;
    min-width: 3.5rem;
    text-align: right;
  }

  /* Mobile: stack duration under name, price stays right */
  @media (max-width: 639px) {
    .service-row {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
      gap: 0.25rem 1rem;
    }
    .service-main   { grid-row: 1; grid-column: 1; }
    .service-duration { grid-row: 2; grid-column: 1; text-align: left; }
    .service-price  { grid-row: 1 / 3; grid-column: 2; align-self: center; }
  }
</style>

<script>
  const tabs   = document.querySelectorAll('.tab-btn');
  const panels = document.querySelectorAll('.services-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');

      const branch = (tab as HTMLElement).dataset.branch;
      panels.forEach(p => { p.classList.remove('active'); (p as HTMLElement).hidden = true; });

      const target = branch === 'newcastle'
        ? document.getElementById('services-ncl')
        : document.getElementById('services-dur');
      target?.classList.add('active');
      if (target) (target as HTMLElement).hidden = false;
    });
  });
</script>
